{
    "name": "aymeric/redirects-checker",
    "description": "Detecte les chaines, boucles et 404 dans les redirections 301",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "RedirectsChecker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "serve": "php -S localhost:8080"
    }
}
